APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Для `php artisan migrate:fresh --env=testing` потрібен файл `.env.testing` з окремим DB_DATABASE
# (наприклад sitezoo_test), інакше Artisan використає базу з `.env` і може стерти дані.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Filament /admin: доступ лише з роллю admin або manager (Spatie). Якщо 403 після входу через Google на вітрині —
# призначте роль: php artisan shop:grant-admin ваш@email.com
# Після migrate --seed: логін за замовчуванням (змініть у Filament → меню користувача → Профіль → новий пароль):
# SHOP_ADMIN_EMAIL=admin@sitezoo.local
# SHOP_ADMIN_PASSWORD=Admin0000
# Або: php artisan shop:ensure-admin (те саме дефолтне Admin0000, якщо не передати --password)

# LiqPay (опційно; якщо порожньо — після чекауту одразу сторінка успіху без онлайн-оплати)
# LIQPAY_PUBLIC_KEY=
# LIQPAY_PRIVATE_KEY=
# LIQPAY_SANDBOX=true

# Google OAuth (вітрина; redirect URI має збігатися з Google Cloud Console)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=  (опційно; якщо порожньо — береться APP_URL + /auth/google/callback)
# Лише якщо PHP видає cURL error 60 (часто Windows): завантажте https://curl.se/ca/cacert.pem,
# покладіть куди завгодно (напр. папка проєкту storage/certs/cacert.pem) і вкажіть:
# GOOGLE_HTTP_CAINFO=storage/certs/cacert.pem
# або повний шлях, напр. GOOGLE_HTTP_CAINFO="C:\Users\ВашеІмя\Downloads\cacert.pem"
# На типовому Linux-хості зазвичай нічого додавати не потрібно — система вже має CA.
