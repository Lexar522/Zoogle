# Скопіюйте цей файл на сервер як .env і заповніть значення.
# Не комітьте реальний .env у Git.

APP_NAME="ZOOGLE"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ваш-домен.ua

# Для Laravel 11+ ключ генеруйте один раз на сервері:
# php artisan key:generate

APP_LOCALE=uk
APP_FALLBACK_LOCALE=uk
APP_FAKER_LOCALE=en_UK

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- База (на хості зазвичай MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# SQLite на хості допустимо лише якщо провайдер дозволяє запис у файл і ви знаєте шлях
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ваш-домен.ua
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Файл живе лише локально під час збірки; на сервер потрібна вже каталог public/build/

# Інтеграції див. також коментарі в app/.env.example (LiqPay, WayForPay, Nova Poshta, Google OAuth тощо)
